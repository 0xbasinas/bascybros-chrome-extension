{
  "name": "bascybros-chrome-extension",
  "displayName": "BascyBros",
  "version": "1.0.0",
  "description": "Capture cybersecurity notes, commands, and resources to your BascyBros dashboard",
  "author": "0xbasinas <0xbasinas.dev>",
  "scripts": {
    "dev": "plasmo dev --no-source-maps",
    "build": "plasmo build --no-source-maps",
    "build:chrome": "plasmo build --target=chrome-mv3 --no-source-maps",
    "build:firefox": "plasmo build --target=firefox-mv3 --no-source-maps",
    "package": "plasmo package --tag=chrome",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/chrome-extension": "3.1.21",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "3.4.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "key": "$CRX_PUBLIC_KEY",
    "host_permissions": [
      "$PLASMO_PUBLIC_CLERK_SYNC_HOST/*",
      "$CLERK_FRONTEND_API/*"
    ],
    "permissions": [
      "activeTab",
      "cookies",
      "contextMenus",
      "storage",
      "scripting",
      "clipboardWrite"
    ],
    "commands": {
      "quick-capture-note": {
        "suggested_key": {
          "default": "Ctrl+Shift+N"
        },
        "description": "Capture selected text"
      },
      "quick-capture-resource": {
        "suggested_key": {
          "default": "Ctrl+Shift+L"
        },
        "description": "Save current page as a Resource"
      },
      "_execute_action": {
        "suggested_key": {
          "default": "Ctrl+Shift+B"
        }
      }
    }
  }
}
